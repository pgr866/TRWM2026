{
  "name": "trwm2026",
  "image": "node:24-alpine",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind",
    "source=trwm2026-node-modules,target=/app/node_modules,type=volume"
  ],
  "appPort": [3000],
  "workspaceFolder": "/app",
  "remoteUser": "root",
  "postCreateCommand": "apk add --no-cache git bash && npm i -g npm@latest && npm ci --prefix /app && git -C /app -c safe.directory=/app config url.\"https://github.com/\".insteadOf \"git@github.com:\"",
  "postStartCommand": "/bin/bash -i -c 'npm run dev'",
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "github.copilot-chat",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "christian-kohler.path-intellisense",
        "echoapi.echoapi-for-vscode",
        "mikestead.dotenv"
      ]
    }
  }
}
