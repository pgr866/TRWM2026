extends layout

block content
    .row.banner
        .col-12
            h1 Review Star
    .row
        .col-12.col-lg-9
           form
                .form-group 
                    label(for="name") Name 
                    input.form-control(type="text" id="name")
                .form-group
                    label(for="rating") Rating
                    select.form-control(id="rating")
                        option 0
                        option 1
                        option 2
                        option 3
                        option 4
                        option 5
                .form-group
                    label(for="review") Review
                    textarea.form-control(id="review" placeholder="Ejemplo, no me gusta")
                button.btn.btn-primary.float-right(type="submit") Add my review
